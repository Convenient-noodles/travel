<view class="history-container">
  <view class="nav-bar" style="height: {{navBarHeight}}rpx; padding-top: {{safeAreaTop}}rpx;">
    <view class="nav-back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="nav-title">浏览历史</text>
    <view class="nav-placeholder"></view>
  </view>

  <view class="filter-bar" style="top: {{navBarHeight}}rpx;">
    <scroll-view class="filter-scroll" scroll-x enable-flex>
      <view class="filter-list">
        <view
          class="filter-item {{currentFilter === index ? 'active' : ''}}"
          wx:for="{{filters}}"
          wx:key="index"
          data-index="{{index}}"
          bindtap="onFilterChange"
        >
          <text class="filter-text">{{item}}</text>
          <view class="filter-underline" wx:if="{{currentFilter === index}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="content-area" style="margin-top: {{contentTop}}rpx;">
    <scroll-view
      class="history-scroll"
      scroll-y
      enable-back-to-top
      bindscrolltolower="onLoadMore"
    >
      <view class="history-list" wx:if="{{filteredList.length > 0}}">
        <view
          class="history-card"
          wx:for="{{filteredList}}"
          wx:key="id"
          data-item="{{item}}"
          bindtap="onCardTap"
        >
          <image
            class="card-image"
            src="{{item.coverImage}}"
            mode="aspectFill"
            lazy-load
          ></image>
          <view class="card-content">
            <view class="card-header">
              <text class="card-title">{{item.title}}</text>
              <view class="card-type {{item.typeClass}}">
                <text class="type-text">{{item.typeName}}</text>
              </view>
            </view>
            <text class="card-desc">{{item.description}}</text>
            <view class="card-footer">
              <text class="card-time">{{item.viewTime}}</text>
              <view class="card-delete" catchtap="onDeleteItem" data-id="{{item.id}}">
                <text class="delete-icon">🗑</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="loading-more" wx:if="{{loading}}">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <view class="no-more" wx:if="{{noMore && filteredList.length > 0}}">
        <text class="no-more-text">已显示全部内容</text>
      </view>

      <view class="empty-tip" wx:if="{{!loading && filteredList.length === 0}}">
        <text class="empty-icon">📭</text>
        <text class="empty-title">暂无浏览历史</text>
        <text class="empty-desc">快去发现精彩内容吧</text>
        <view class="empty-btn" bindtap="onGoDiscover">
          <text>去发现</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="bottom-bar" wx:if="{{filteredList.length > 0}}">
    <view class="clear-btn" bindtap="onClearAll">
      <text class="clear-icon">🗑</text>
      <text class="clear-text">清空历史</text>
    </view>
  </view>
</view>