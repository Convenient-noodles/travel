.history-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  overflow: hidden;
  box-sizing: border-box;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-back-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.92);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.nav-placeholder {
  width: 64rpx;
}

.filter-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  height: 88rpx;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-scroll {
  width: 100%;
  height: 100%;
  white-space: nowrap;
}

.filter-list {
  display: inline-flex;
  align-items: center;
  height: 100%;
  padding: 0 20rpx;
}

.filter-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  height: 100%;
  transition: all 0.3s;
}

.filter-text {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s;
}

.filter-item.active .filter-text {
  color: #ff6b35;
  font-weight: bold;
}

.filter-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  border-radius: 3rpx;
}

.content-area {
  flex: 1;
  padding-bottom: 120rpx;
}

.history-scroll {
  height: calc(100vh - 176rpx - 120rpx - env(safe-area-inset-bottom));
}

.history-list {
  padding: 20rpx;
}

.history-card {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.history-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20rpx;
  min-width: 0;
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.card-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-type {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.card-type.scenic {
  background: linear-gradient(135deg, #4CAF50, #81C784);
  color: #fff;
}

.card-type.strategy {
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  color: #fff;
}

.card-type.food {
  background: linear-gradient(135deg, #FF9800, #FFB74D);
  color: #fff;
}

.type-text {
  font-size: 20rpx;
  font-weight: 600;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-top: 8rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.card-time {
  font-size: 22rpx;
  color: #999;
}

.card-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 50%;
  transition: all 0.2s;
}

.card-delete:active {
  background-color: #ffcccc;
  transform: scale(0.9);
}

.delete-icon {
  font-size: 24rpx;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #ddd;
  border-top-color: #ff6b35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
  position: relative;
  padding: 0 30rpx;
}

.no-more-text::before,
.no-more-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 60rpx;
  height: 1rpx;
  background-color: #ddd;
}

.no-more-text::before {
  left: -70rpx;
}

.no-more-text::after {
  right: -70rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
  margin-top: 20rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  border-radius: 40rpx;
  transition: all 0.3s;
}

.empty-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.empty-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: center;
}

.clear-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #FFF5F5, #FFE4E4);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.clear-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.clear-icon {
  font-size: 36rpx;
}

.clear-text {
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: 600;
}

@media screen and (min-width: 768px) {
  .history-card {
    max-width: 600rpx;
    margin-left: auto;
    margin-right: auto;
  }
}