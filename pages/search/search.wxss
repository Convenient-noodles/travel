.search-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  padding-top: calc(60rpx + env(safe-area-inset-top)); /*【改】增大顶部外边距，避免搜索栏被状态栏遮挡 */
  padding-bottom: 20rpx;
  display: flex;
  align-items: center;
  padding-left: 20rpx;
  padding-right: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

.back-btn:active {
  opacity: 0.6;
  transform: scale(0.9);
}

.back-icon {
  font-size: 44rpx;
  color: #333;
  font-weight: bold;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 20rpx;
  height: 72rpx;
  margin-left: 16rpx;
  transition: all 0.3s ease;
}

.search-box:focus-within {
  background: #fff;
  box-shadow: 0 0 0 2rpx #2ECC71;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #333;
}

.placeholder-style {
  color: #bbb;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ccc;
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.clear-btn:active {
  background: #999;
  transform: scale(0.9);
}

.clear-icon {
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
}

.content-scroll {
  flex: 1;
  height: 0;
  margin-top: calc(172rpx + env(safe-area-inset-top)); /*【改】同步header高度变化 */
  padding: 20rpx;
}

.popular-section,
.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.clear-history {
  padding: 8rpx 16rpx;
  transition: all 0.3s ease;
}

.clear-history:active {
  opacity: 0.6;
}

.clear-history-text {
  font-size: 26rpx;
  color: #999;
}

.popular-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.tag-item:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.tag-text {
  font-size: 26rpx;
  color: #2ECC71;
  font-weight: 500;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.history-item:active {
  background: #f5f5f5;
}

.history-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.history-text {
  font-size: 28rpx;
  color: #666;
}

.search-results {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: calc(100vh - calc(172rpx + env(safe-area-inset-top))); /*【改】同步header高度变化 */
  margin-top: calc(172rpx + env(safe-area-inset-top));
}

.category-tabs {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item:active {
  opacity: 0.7;
}

.tab-text {
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #2ECC71;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #2ECC71;
  border-radius: 3rpx;
}

.results-scroll {
  flex: 1;
  height: 0;
  padding: 20rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(46, 204, 113, 0.2);
  border-top-color: #2ECC71;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  transition: all 0.3s ease;
}

.result-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.result-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.result-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.result-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-top: 8rpx;
}

.result-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.result-location {
  font-size: 24rpx;
  color: #999;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-tag {
  font-size: 22rpx;
  color: #2ECC71;
  background: #E8F5E9;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
