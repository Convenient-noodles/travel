.home-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  overflow: hidden; /*【改】阻止页面级滚动，强制scroll-view内部滚动，确保tabBar始终可见 */
}

.header {
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  padding: 20rpx 30rpx 30rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.search-box {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

.content {
  flex: 1;
  height: 0; /*【改】scroll-view在flex布局中必须同时设置flex:1和height:0才能正确约束高度 */
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: #fff;
  font-size: 28rpx;
  padding: 60rpx 30rpx 20rpx;
}

.quick-entry {
  display: flex;
  justify-content: space-between;
  padding: 40rpx 20rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.quick-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 16rpx;
}

.quick-name {
  font-size: 24rpx;
  color: #333;
}

.section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.scenic-scroll {
  white-space: nowrap;
  width: 100%;
}

.scenic-card {
  display: inline-block;
  width: 280rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f9f9f9;
}

.scenic-image {
  width: 280rpx;
  height: 320rpx;
}

.scenic-info {
  padding: 16rpx;
}

.scenic-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.scenic-location {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.scenic-rating {
  display: flex;
  align-items: center;
}

.star {
  color: #FFB800;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.score {
  font-size: 24rpx;
  color: #FFB800;
  font-weight: 500;
}

.strategy-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.strategy-item {
  display: flex;
  background: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.strategy-image {
  width: 200rpx;
  height: 150rpx;
  flex-shrink: 0;
}

.strategy-content {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.strategy-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
}

.strategy-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.strategy-author {
  font-size: 22rpx;
  color: #999;
}

.strategy-date {
  font-size: 22rpx;
  color: #999;
}

.tab-bar {
  flex-shrink: 0; /*【改】改用flex布局替代fixed定位，利用overflow:hidden容器+flex确保永远在底部 */
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

.tab-item.active .tab-text {
  color: #2ECC71;
}
