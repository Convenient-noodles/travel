.list-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 100%);
  padding: 30rpx 30rpx;
  padding-top: calc(60rpx + constant(safe-area-inset-top));
  padding-top: calc(60rpx + env(safe-area-inset-top));
  min-height: 140rpx;
  box-sizing: border-box;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
  text-align: center;
}

.header-placeholder {
  width: 60rpx;
}

.filter-bar {
  display: flex;
  background: #fff;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 50rpx;
  background: #f5f5f5;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #2ECC71;
}

.filter-item.active .filter-text {
  color: #fff;
}

.filter-text {
  font-size: 26rpx;
  color: #666;
}

.scenic-grid {
  height: calc(100vh - 240rpx - constant(safe-area-inset-top));
  height: calc(100vh - 240rpx - env(safe-area-inset-top));
}

.grid-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.scenic-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.scenic-image {
  width: 100%;
  height: 240rpx;
}

.scenic-info {
  padding: 20rpx;
}

.scenic-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scenic-location {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.scenic-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.scenic-duration {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #ff6b35;
  margin-bottom: 8rpx;
}

.duration-icon {
  margin-right: 6rpx;
}

.scenic-rating {
  display: flex;
  align-items: center;
}

.star {
  color: #FFB800;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.score {
  font-size: 24rpx;
  color: #FFB800;
  font-weight: 500;
}