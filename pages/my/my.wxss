.my-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.user-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  position: relative;
  margin-bottom: 24rpx;
}

.avatar-choose-btn {
  position: relative;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #eee;
}

.avatar-tip {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.6);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.avatar-tip text {
  font-size: 20rpx;
  color: #fff;
}

.avatar-edit-tip {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(39, 174, 96, 0.8);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.avatar-edit-tip text {
  font-size: 20rpx;
  color: #fff;
}

.nickname-input-wrapper {
  width: 100%;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: center;
}

.nickname-input {
  width: 70%;
  height: 72rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  border-bottom: 2rpx solid #eee;
  padding: 0 20rpx;
}

.nickname-input.logged-in {
  font-size: 34rpx;
  font-weight: 600;
  border-bottom: 2rpx solid #eee;
}

.nickname-display-wrapper {
  width: 100%;
  margin-bottom: 12rpx;
  display: flex;
  justify-content: center;
}

.login-hint {
  font-size: 24rpx;
  color: #999;
}

.menu-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-btn {
  margin-top: 60rpx;
  background: #fff;
  border-radius: 50rpx;
  padding: 28rpx;
  text-align: center;
  border: 2rpx solid #E74C3C;
}

.logout-btn text {
  font-size: 32rpx;
  color: #E74C3C;
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999; /*【改】提升层级，确保不被scroll-view原生组件覆盖 */
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999;
}

.tab-item.active .tab-text {
  color: #E74C3C;
}