.orders-container {
  min-height: 100vh;
  background: #f5f6fa;
}

.tabs-bar {
  display: flex;
  background: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #27AE60;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #27AE60;
  border-radius: 2rpx;
}

.orders-list {
  padding: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-hotel {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.order-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.order-status.pending {
  background: #FFF3E0;
  color: #E65100;
}

.order-status.paid {
  background: #E8F5E9;
  color: #27AE60;
}

.order-status.refunding {
  background: #FFF8E1;
  color: #F57F17;
}

.order-status.refunded {
  background: #f0f0f0;
  color: #999;
}

.order-body {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.order-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.order-thumb-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.order-room {
  font-size: 26rpx;
  color: #333;
}

.order-date {
  font-size: 22rpx;
  color: #888;
}

.order-no {
  font-size: 20rpx;
  color: #bbb;
  font-family: monospace;
}

.order-price {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
}

.price-currency {
  font-size: 22rpx;
  color: #e74c3c;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #e74c3c;
}

.order-refund-info {
  margin-top: 12rpx;
  padding: 10rpx 16rpx;
  background: #FFF8E1;
  border-left: 4rpx solid #F57F17;
  border-radius: 4rpx;
}

.refund-info-text {
  font-size: 22rpx;
  color: #E65100;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-time {
  font-size: 22rpx;
  color: #bbb;
}

.footer-right {
  display: flex; align-items: center; gap: 16rpx;
}

.sync-tag {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 16rpx;
  display: flex; align-items: center;
}

.sync-tag.synced {
  background: #ecfdf5; color: #166534; border: 1rpx solid #a7f3d0;
}

.sync-tag.unsynced {
  background: #fff7ed; color: #c2410c; border: 1rpx solid #fed7aa;
}

.order-refund {
  padding: 8rpx 20rpx;
  background: #FFF3E0;
  border: 1rpx solid #FFB74D;
  border-radius: 20rpx;
}

.order-refund text {
  font-size: 24rpx;
  color: #E65100;
}

.order-refunding {
  padding: 8rpx 20rpx;
  background: #f5f5f5;
  border: 1rpx solid #e0e0e0;
  border-radius: 20rpx;
}

.order-refunding text {
  font-size: 24rpx;
  color: #999;
}

.order-refresh-status {
  padding: 8rpx 20rpx;
  background: #E3F2FD;
  border: 1rpx solid #90CAF9;
  border-radius: 20rpx;
}

.order-refresh-status text {
  font-size: 24rpx;
  color: #1565C0;
}

.order-delete {
  padding: 8rpx 16rpx;
}

.order-delete text {
  font-size: 24rpx;
  color: #e74c3c;
}

.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #ccc;
}

.loading-state {
  padding: 120rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}
