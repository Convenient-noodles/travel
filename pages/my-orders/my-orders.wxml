<view class="orders-container">
  <view class="tabs-bar">
    <view
      class="tab-item {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="orders-list" wx:if="{{!loading && filteredOrders.length > 0}}">
    <view
      class="order-card"
      wx:for="{{filteredOrders}}"
      wx:key="orderNo"
      data-order="{{item}}"
      bindtap="onOrderTap"
    >
      <view class="order-header">
        <text class="order-hotel">{{item.hotelName}}</text>
        <view class="order-status {{item.status}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <view class="order-body">
        <image class="order-thumb" src="{{item.hotelImage}}" mode="aspectFill" wx:if="{{item.hotelImage}}" />
        <view class="order-thumb-placeholder" wx:else>🏨</view>
        <view class="order-info">
          <text class="order-room">{{item.roomName}}</text>
          <text class="order-date">入住：{{item.checkInDate}}  ·  {{item.nights || 1}}晚</text>
          <text class="order-no">订单号：{{item.orderNo}}</text>
        </view>
        <view class="order-price">
          <text class="price-currency">¥</text>
          <text class="price-value">{{item.amount}}</text>
        </view>
      </view>

      <view class="order-refund-info" wx:if="{{item.status === 'refunding' && item.refundReason}}">
        <text class="refund-info-text">退款申请：{{item.refundReason}}</text>
      </view>

      <view class="order-footer">
        <text class="order-time">{{item.createTimeStr || ''}}</text>
        <view class="footer-right">
          <!-- 同步状态 -->
          <view class="sync-tag synced" wx:if="{{item.syncedToBackend !== false}}">
            <text>☁️ 已同步</text>
          </view>
          <view class="sync-tag unsynced" wx:else catchtap="retrySyncPayment" data-orderno="{{item.orderNo}}">
            <text>⚠ 点击重试同步</text>
          </view>

          <!-- 退款操作 -->
          <view class="order-refund" wx:if="{{item.status === 'paid'}}" catchtap="onRefundOrder" data-orderno="{{item.orderNo}}">
            <text>申请退款</text>
          </view>

          <!-- 退款中 -->
          <block wx:if="{{item.status === 'refunding'}}">
            <view class="order-refunding">
              <text>退款处理中</text>
            </view>
            <view class="order-refresh-status" catchtap="onQueryOrderStatus" data-orderno="{{item.orderNo}}">
              <text>🔄 刷新状态</text>
            </view>
          </block>

          <!-- 删除 -->
          <view class="order-delete" catchtap="onDeleteOrder" data-orderno="{{item.orderNo}}">
            <text>删除</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!loading && filteredOrders.length === 0}}">
    <view class="empty-icon">📋</view>
    <text class="empty-title">暂无订单</text>
    <text class="empty-desc">预订酒店后，订单将显示在这里</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>
</view>
