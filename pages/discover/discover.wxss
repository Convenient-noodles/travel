.discover-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  overflow: hidden;
  box-sizing: border-box;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-back-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.92);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.nav-search-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-search-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.92);
}

.search-icon {
  font-size: 32rpx;
}

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 99;
  height: 88rpx;
  background-color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tab-scroll {
  width: 100%;
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  align-items: center;
  padding: 0 20rpx;
}

.tab-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: all 0.3s;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #ff6b35;
  font-weight: bold;
}

.tab-underline {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  border-radius: 3rpx;
}

.content-area {
  flex: 1;
  padding-bottom: env(safe-area-inset-bottom);
}

.article-scroll {
  min-height: 100vh;
  box-sizing: border-box;
}

.article-list {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx;
  box-sizing: border-box;
}

.article-card {
  width: 48%;
  margin: 1%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
  box-sizing: border-box;
}

.article-card:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  padding-top: 56.25%;
  background-color: #f0f0f0;
}

.card-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.card-tag {
  position: absolute;
  top: 0;
  right: 0;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  border-radius: 0 0 0 12rpx;
}

.card-content {
  padding: 20rpx;
}

.card-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-date {
  font-size: 22rpx;
  color: #999;
}

.card-views {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.views-icon {
  font-size: 22rpx;
}

.views-count {
  font-size: 22rpx;
  color: #999;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #ddd;
  border-top-color: #ff6b35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.no-more-text {
  font-size: 26rpx;
  color: #ccc;
  position: relative;
  padding: 0 30rpx;
}

.no-more-text::before,
.no-more-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 60rpx;
  height: 1rpx;
  background-color: #ddd;
}

.no-more-text::before {
  left: -70rpx;
}

.no-more-text::after {
  right: -70rpx;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

@media screen and (min-width: 768px) {
  .article-card {
    width: 32%;
    margin: 0.66%;
  }
}