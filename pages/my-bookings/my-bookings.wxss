.bookings-container {
  min-height: 100vh;
  background: #f5f6fa;
}

.bookings-list { padding: 20rpx; }

.booking-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx;
}

.booking-header {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;
}

.booking-name {
  font-size: 30rpx; font-weight: 600; color: #1a1a1a;
  flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-right: 16rpx;
}

.booking-status {
  font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 20rpx; flex-shrink: 0;
}

.booking-status.confirmed {
  background: #E8F5E9; color: #1ABC9C;
}

.booking-status.cancelled {
  background: #f0f0f0; color: #999;
}

.booking-body {
  display: flex; gap: 16rpx; align-items: center;
}

.booking-thumb {
  width: 100rpx; height: 100rpx; border-radius: 10rpx; flex-shrink: 0;
}

.booking-thumb-placeholder {
  width: 100rpx; height: 100rpx; border-radius: 10rpx;
  background: #f0f0f0; display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; flex-shrink: 0;
}

.booking-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }

.booking-row {
  display: flex; align-items: center; gap: 6rpx;
}

.booking-row .info-icon { font-size: 22rpx; }
.booking-row .info-text { font-size: 24rpx; color: #666; }

.booking-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5;
}

.booking-time { font-size: 22rpx; color: #bbb; }

.footer-right {
  display: flex; align-items: center; gap: 12rpx;
}

.sync-tag {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 16rpx;
}

.sync-tag.synced {
  background: #ecfdf5; color: #166534; border: 1rpx solid #a7f3d0;
}

.sync-tag.unsynced {
  background: #fff7ed; color: #c2410c; border: 1rpx solid #fed7aa;
}

.booking-cancel { padding: 8rpx 20rpx; }

.booking-cancel text { font-size: 24rpx; color: #e74c3c; }

.booking-delete { padding: 8rpx 20rpx; }
.booking-delete text { font-size: 24rpx; color: #999; }

.empty-state { padding: 120rpx 0; text-align: center; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-title { font-size: 30rpx; color: #999; display: block; margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; color: #ccc; }

.loading-state { padding: 120rpx 0; text-align: center; }
.loading-text { font-size: 26rpx; color: #999; }
