.about-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  overflow: hidden;
  box-sizing: border-box;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-back-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
  transform: scale(0.92);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.nav-placeholder {
  width: 64rpx;
}

.content-area {
  flex: 1;
}

.about-content {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.app-icon {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.app-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #ff6b35;
}

.section-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

.intro-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.guizhou-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.guizhou-card {
  display: flex;
  align-items: center;
  background-color: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.guizhou-card:last-child {
  margin-bottom: 0;
}

.guizhou-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.guizhou-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.guizhou-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.guizhou-desc {
  font-size: 24rpx;
  color: #999;
}

.features-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: linear-gradient(135deg, #fff8f5, #fff);
  border-radius: 16rpx;
  border: 1rpx solid #ffeee5;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.contact-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.contact-item:last-child {
  margin-bottom: 0;
}

.contact-item:active {
  background-color: #f0f0f0;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #666;
}

.contact-item:first-of-type .contact-text {
  color: #ff6b35;
  font-weight: 500;
}

.links-section {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.link-item {
  padding: 10rpx 20rpx;
}

.link-text {
  font-size: 26rpx;
  color: #ff6b35;
  text-decoration: underline;
}

.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.copyright-text {
  font-size: 22rpx;
  color: #ccc;
  text-align: center;
}

@media screen and (min-width: 768px) {
  .about-content {
    max-width: 600rpx;
    margin: 0 auto;
  }
}