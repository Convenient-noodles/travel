.collection-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  padding-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  margin-left: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.back-btn:active {
  opacity: 0.6;
  transform: scale(0.9);
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
}

.header-placeholder {
  width: 72rpx;
  margin-right: 20rpx;
}

.tabs-container {
  position: fixed;
  top: calc(112rpx + env(safe-area-inset-top));
  left: 0;
  right: 0;
  z-index: 99;
  background: #fff;
  display: flex;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #eee;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item:active {
  opacity: 0.7;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: #2ECC71;
  font-weight: 600;
}

.tab-indicator {
  width: 40rpx;
  height: 6rpx;
  background: transparent;
  border-radius: 3rpx;
  margin-top: 12rpx;
  transition: all 0.3s ease;
}

.tab-item.active .tab-indicator {
  background: #2ECC71;
}

.collection-scroll {
  flex: 1;
  height: 0;
  margin-top: calc(192rpx + env(safe-area-inset-top));
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(46, 204, 113, 0.2);
  border-top-color: #2ECC71;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
  border-width: 4rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.collection-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.collection-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  transition: all 0.3s ease;
}

.collection-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.item-wrapper {
  display: flex;
  padding: 24rpx;
  transition: transform 0.3s ease;
}

.collection-item.swiping .item-wrapper {
  transform: translateX(-160rpx);
}

.item-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.item-content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-location {
  font-size: 24rpx;
  color: #999;
}

.item-time {
  font-size: 22rpx;
  color: #bbb;
}

.delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  display: flex;
  align-items: center;
  justify-content: center;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.collection-item.swiping .delete-btn {
  transform: translateX(0);
}

.delete-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.load-more,
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.load-more-text,
.no-more-text {
  font-size: 26rpx;
  color: #999;
  margin-left: 12rpx;
}
