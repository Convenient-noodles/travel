<view class="collection-container">
  <view class="header">
    <view class="back-btn" bindtap="onBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">我的收藏</text>
    <view class="header-placeholder"></view>
  </view>

  <view class="tabs-container">
    <view 
      class="tab-item {{currentTab === 'scenic' ? 'active' : ''}}" 
      wx:for="{{tabs}}" 
      wx:key="type"
      data-type="{{item.type}}"
      bindtap="onTabChange"
    >
      <text class="tab-text">{{item.name}}</text>
      <view class="tab-indicator {{currentTab === item.type ? 'active' : ''}}"></view>
    </view>
  </view>

  <scroll-view 
    class="collection-scroll" 
    scroll-y="true" 
    bindscrolltolower="onReachBottom"
    lower-threshold="50"
  >
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view class="empty-container" wx:elif="{{!loading && currentList.length === 0}}">
      <view class="empty-icon">📦</view>
      <text class="empty-text">暂无收藏{{currentTab === 'scenic' ? '景点' : '攻略'}}</text>
      <text class="empty-hint">快去收藏你喜欢的内容吧</text>
    </view>

    <view class="collection-list" wx:else>
      <view 
        class="collection-item {{swipingId === item.id ? 'swiping' : ''}}" 
        wx:for="{{currentList}}" 
        wx:key="id"
        data-id="{{item.id}}"
        data-type="{{currentTab}}"
        bindtap="onItemTap"
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd"
      >
        <view class="item-wrapper">
          <image class="item-image" src="{{item.image}}" mode="aspectFill" lazy-load="{{true}}"></image>
          <view class="item-content">
            <text class="item-title">{{item.name || item.title}}</text>
            <view class="item-meta">
              <text class="item-location">📍 {{item.location || item.type || '攻略'}}</text>
              <text class="item-time">{{formatTime(item.collectTime)}}</text>
            </view>
          </view>
        </view>
        <view class="delete-btn" data-id="{{item.id}}" catchtap="onDeleteTap">
          <text class="delete-text">取消收藏</text>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{!loading && hasMore && currentList.length > 0}}">
      <view class="loading-spinner small"></view>
      <text class="load-more-text">加载更多...</text>
    </view>

    <view class="no-more" wx:if="{{!loading && !hasMore && currentList.length > 0}}">
      <text class="no-more-text">没有更多了</text>
    </view>
  </scroll-view>
</view>
