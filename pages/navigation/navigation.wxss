.nav-container {
  min-height: 100vh;
  background-color: #fff;
}

.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 20rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.4));
}

.nav-back-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255,255,255,0.2);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.nav-back-btn:active {
  background-color: rgba(255,255,255,0.4);
  transform: scale(0.95);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.nav-close-btn {
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255,255,255,0.2);
  border-radius: 50%;
  backdrop-filter: blur(10px);
}

.nav-close-btn:active {
  background-color: rgba(255,255,255,0.4);
  transform: scale(0.95);
}

.close-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.map-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
}

.nav-map {
  width: 100%;
  height: 100vh; /*【改】确保地图占满整个屏幕高度 */
}

.location-info {
  position: absolute;
  bottom: 520rpx;
  left: 30rpx;
  right: 30rpx;
  background-color: rgba(255,255,255,0.95);
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.location-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.location-address {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 默认状态：底部操作面板 */
.nav-action-panel {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  background-color: rgba(255,255,255,0.98);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 30rpx rgba(0,0,0,0.15);
}

.nav-modes {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.nav-mode {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.nav-mode.active {
  background-color: #ff6b35;
}

.nav-mode.active .mode-icon,
.nav-mode.active .mode-text {
  color: #fff;
}

.mode-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.mode-text {
  font-size: 26rpx;
  color: #666;
}

.distance-info {
  text-align: center;
  padding: 16rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.distance-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 按钮组 */
.nav-btn-group {
  display: flex;
  gap: 20rpx;
}

.nav-start-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: linear-gradient(135deg, #ff6b35, #ff8f5c);
  border-radius: 16rpx;
}

.nav-start-btn:active {
  opacity: 0.85;
}

.start-icon {
  font-size: 32rpx;
  color: #fff;
  margin-right: 12rpx;
}

.start-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 退出按钮（默认状态） */
.nav-exit-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: #fff;
  border: 2rpx solid #E74C3C;
  border-radius: 16rpx;
}

.nav-exit-btn:active {
  background: #fdf2f2;
}

.exit-text {
  font-size: 32rpx;
  color: #E74C3C;
  font-weight: bold;
}

/* ==================== 导航中状态面板：紧凑底部条 ==================== */
.navigating-panel {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  background-color: rgba(255,255,255,0.98);
  border-radius: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.2);
  backdrop-filter: blur(10px);
}

/* 左侧：导航中徽标 */
.navigating-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding-right: 20rpx;
  border-right: 2rpx solid #eee;
  flex-shrink: 0;
}

.navigating-pulse {
  width: 16rpx;
  height: 16rpx;
  background: #27AE60;
  border-radius: 50%;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  50% {
    transform: scale(1.4);
    opacity: 0.4;
  }
  100% {
    transform: scale(0.8);
    opacity: 1;
  }
}

.navigating-badge-text {
  font-size: 24rpx;
  color: #27AE60;
  font-weight: bold;
}

/* 中间：目的地和距离信息 */
.navigating-info {
  flex: 1;
  margin: 0 20rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.navigating-to-label {
  font-size: 22rpx;
  color: #999;
}

.navigating-to-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin: 4rpx 0;
}

.navigating-stats {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧：结束按钮 */
.navigating-end-btn {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  background: #E74C3C;
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(231, 76, 60, 0.3);
}

.navigating-end-btn:active {
  background: #c0392b;
  transform: scale(0.95);
}

.navigating-end-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.navigating-end-text {
  font-size: 20rpx;
  color: #fff;
}
