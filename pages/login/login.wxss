.login-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(135deg, #2ECC71 0%, #27AE60 50%, #1ABC9C 100%);
}

.bg-image {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  opacity: 0.9;
}

.login-content {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
  z-index: 10;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff 0%, #f8f8f8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.logo-text {
  font-size: 72rpx;
  color: #27AE60;
  font-weight: bold;
}

.app-title {
  font-size: 48rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 8rpx;
}

.login-tip {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 50rpx;
}

/* 头像昵称填写表单 */
.profile-form {
  width: 85%;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
  width: 80rpx;
  margin-right: 20rpx;
}

.avatar-choose-btn {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  border: none;
  margin: 0;
  line-height: normal;
}

.avatar-choose-btn::after {
  border: none;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 20rpx;
}

.avatar-choose-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.nickname-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #fff;
}

.nickname-input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}

.login-btn {
  width: 85%;
  height: 100rpx;
  border-radius: 50rpx;
  background: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 80rpx;
  padding: 0;
}

.login-btn::after {
  border: none;
}

.login-btn-text {
  font-size: 34rpx;
  color: #27AE60;
  font-weight: 600;
}

.login-btn[loading] .login-btn-text {
  display: none;
}

.login-btn[disabled] {
  opacity: 0.7;
}

.privacy-section {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  padding: 0 30rpx;
}

.privacy-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.privacy-link {
  font-size: 22rpx;
  color: #fff;
  margin: 0 8rpx;
  text-decoration: underline;
}
