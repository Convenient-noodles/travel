page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.food-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.collect-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.collect-btn:active {
  transform: scale(0.9);
}

.collect-icon {
  font-size: 40rpx;
}

.share-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
}

.share-icon {
  font-size: 36rpx;
  color: #333;
}

.content-scroll {
  height: 100vh;
  padding-top: calc(env(safe-area-inset-top) + 80rpx);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.detail-content {
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

.image-section {
  position: relative;
  width: 100%;
  height: 500rpx;
}

.food-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.tag-list {
  display: flex;
  gap: 16rpx;
}

.tag-item {
  padding: 8rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
}

.price-tag {
  background-color: #4CAF50;
  color: #fff;
}

.info-section {
  padding: 24rpx;
  background-color: #fff;
}

.food-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.food-region {
  font-size: 28rpx;
  color: #666;
}

.divider {
  height: 16rpx;
  background-color: #f5f5f5;
}

.section {
  padding: 24rpx;
  background-color: #fff;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
}

.shop-list {
  margin-top: 16rpx;
}

.shop-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: all 0.3s ease;
}

.shop-item:active {
  background-color: #f0f0f0;
  transform: scale(0.98);
}

.shop-info {
  flex: 1;
}

.shop-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.shop-address {
  font-size: 26rpx;
  color: #666;
}

.shop-actions {
  text-align: right;
}

.shop-phone {
  display: block;
  font-size: 26rpx;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.nav-icon {
  font-size: 26rpx;
  color: #4CAF50;
}

.no-shop {
  text-align: center;
  padding: 40rpx;
}

.no-shop-text {
  font-size: 28rpx;
  color: #999;
}

.tips-list {
  margin-top: 16rpx;
}

.tip-item {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.bottom-spacing {
  height: 40rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.action-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.98);
}

.action-btn.center {
  width: 300rpx;
  background-color: #4CAF50;
}

.action-btn.center .btn-text {
  color: #fff;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
}

/* 图片集样式 */
.images-scroll {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.images-list {
  display: inline-flex;
  gap: 16rpx;
}

.gallery-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  object-fit: cover;
  transition: all 0.3s ease;
}

.gallery-image:active {
  transform: scale(0.95);
}