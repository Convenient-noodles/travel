.red-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  overflow: hidden;
  box-sizing: border-box;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-back-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.nav-placeholder {
  width: 64rpx;
}

.content-area {
  flex: 1;
}

.detail-content {
  padding-bottom: 40rpx;
}

.header-image-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.header-image {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-rating {
  display: flex;
  align-items: center;
}

.star {
  color: #FFB800;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.score {
  font-size: 28rpx;
  color: #FFB800;
  font-weight: 600;
}

.info-section {
  display: flex;
  gap: 40rpx;
  padding: 24rpx 30rpx;
  background-color: #fff;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.section {
  margin-top: 20rpx;
  padding: 30rpx;
  background-color: #fff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #E74C3C;
  display: block;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #fff5f5;
  border-radius: 30rpx;
}

.feature-icon {
  font-size: 24rpx;
  color: #E74C3C;
  margin-right: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
}

.tips-icon {
  font-size: 26rpx;
  color: #27AE60;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.nav-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #E74C3C, #C0392B);
  border-radius: 44rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.nav-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.bottom-space {
  height: 150rpx;
}