.culture-detail-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #1ABC9C, #16A085);
  overflow: hidden;
  box-sizing: border-box;
}

.nav-back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transition: all 0.2s;
}

.nav-back-btn:active {
  background-color: rgba(255, 255, 255, 0.4);
}

.back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}

.nav-placeholder {
  width: 64rpx;
}

.content-area {
  flex: 1;
}

.detail-content {
  padding-bottom: 40rpx;
}

.header-image-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
}

.header-image {
  width: 100%;
  height: 100%;
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
  padding: 40rpx 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.header-rating {
  display: flex;
  align-items: center;
}

.star {
  color: #FFB800;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.score {
  font-size: 28rpx;
  color: #FFB800;
  font-weight: 600;
}

.info-section {
  display: flex;
  gap: 40rpx;
  padding: 24rpx 30rpx;
  background-color: #fff;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.section {
  margin-top: 20rpx;
  padding: 30rpx;
  background-color: #fff;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1ABC9C;
  display: block;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background-color: #f0fff5;
  border-radius: 30rpx;
}

.feature-icon {
  font-size: 24rpx;
  color: #1ABC9C;
  margin-right: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
}

.tips-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.book-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1ABC9C, #16A085);
  border-radius: 44rpx;
  border: none;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.book-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.bottom-space {
  height: 150rpx;
}

/* ========== 预约弹窗 ========== */
.booking-modal-root {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200;
}

.booking-modal-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.booking-modal-panel {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
  display: flex; flex-direction: column;
  max-height: 80vh;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 30rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title { font-size: 32rpx; font-weight: 700; color: #333; }

.modal-close-btn {
  font-size: 36rpx; color: #999;
  width: 48rpx; height: 48rpx;
  display: flex; align-items: center; justify-content: center;
}

.modal-body {
  padding: 20rpx 30rpx;
  flex: 1; overflow-y: auto;
  max-height: 50vh;
}

.form-row {
  display: flex; align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-row:last-child { border-bottom: none; }

.form-label { font-size: 28rpx; color: #333; width: 150rpx; flex-shrink: 0; }

.form-static-value { font-size: 28rpx; color: #666; }

.form-text-input {
  flex: 1; font-size: 28rpx; color: #333;
  padding: 16rpx 0; min-height: 52rpx;
}

.form-picker-value { font-size: 28rpx; color: #333; padding: 8rpx 0; }

.counter-control {
  display: flex; align-items: center; gap: 24rpx;
}

.counter-btn {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #f0f0f0; display: flex;
  align-items: center; justify-content: center;
  font-size: 32rpx; color: #333; font-weight: 600;
  transition: all 0.15s;
}

.counter-btn:active { background: #e0e0e0; }

.counter-disabled { color: #ccc; pointer-events: none; }

.counter-display {
  font-size: 32rpx; font-weight: 600; color: #333;
  min-width: 40rpx; text-align: center;
}

.modal-footer {
  display: flex; gap: 24rpx; padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0; flex-shrink: 0;
}

.footer-cancel-btn {
  flex: 1; text-align: center; padding: 24rpx 0;
  background: #f5f5f5; border-radius: 40rpx;
  font-size: 28rpx; color: #666;
}

.footer-confirm-btn {
  flex: 2; text-align: center; padding: 24rpx 0;
  background: linear-gradient(135deg, #1ABC9C, #16A085);
  border-radius: 40rpx; font-size: 28rpx; color: #fff; font-weight: 600;
}