/* ==================== 容器 & 加载态 ==================== */
.route-container {
  min-height: 100vh;
  background: #f0f5f0;
}

.loading-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f0f5f0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(46, 204, 113, 0.3);
  border-top-color: #27AE60;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* ==================== 顶部导航栏 ==================== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #27AE60, #2ECC71);
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
}

.nav-back:active {
  background: rgba(255,255,255,0.4);
}

.nav-back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-placeholder {
  width: 64rpx;
}

/* ==================== 封面头图 ==================== */
.hero-section {
  position: relative;
  width: 100%;
  height: 480rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.65), transparent);
}

.hero-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.hero-tags {
  display: flex;
  gap: 16rpx;
}

.hero-tag {
  padding: 6rpx 20rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
  backdrop-filter: blur(10px);
}

/* ==================== 主体滚动区 ==================== */
.main-scroll {
  position: relative;
  padding: 20rpx 24rpx;
  height: calc(100vh - 480rpx);
}

/* ==================== 天数选择器卡片 ==================== */
.day-selector-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.day-selector-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.day-selector-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.day-selector-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.day-selector-sub {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
}

.day-tabs {
  white-space: nowrap;
}

.day-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 14rpx;
  background: #f5f5f5;
  min-width: 140rpx;
  transition: all 0.25s;
}

.day-tab.active {
  background: linear-gradient(135deg, #27AE60, #2ECC71);
  box-shadow: 0 4rpx 16rpx rgba(39, 174, 96, 0.3);
}

.day-tab-num {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
}

.day-tab-title {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.day-tab.active .day-tab-num,
.day-tab.active .day-tab-title {
  color: #fff;
}

/* ==================== 当日行程详情卡片 ==================== */
.day-detail-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.day-header {
  margin-bottom: 32rpx;
}

.day-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.day-badge {
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, #27AE60, #2ECC71);
  border-radius: 20rpx;
  flex-shrink: 0;
}

.day-badge-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.day-header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
}

.day-header-line {
  height: 2rpx;
  background: linear-gradient(to right, #27AE60, #e8e8e8);
}

/* ==================== 纵向时间轴 ==================== */
.spots-timeline {
  position: relative;
}

.spot-item {
  display: flex;
  margin-bottom: 32rpx;
}

.spot-item:last-child {
  margin-bottom: 0;
}

/* 时间轴线 */
.timeline-line {
  position: relative;
  width: 40rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #27AE60;
  border: 4rpx solid #d4f0de;
  margin-top: 30rpx;
  z-index: 1;
}

.timeline-connector {
  flex: 1;
  width: 3rpx;
  background: linear-gradient(to bottom, #27AE60, #d4f0de);
  min-height: 60rpx;
}

/* 景点卡片 */
.spot-card {
  flex: 1;
  margin-left: 16rpx;
  background: #f9fbf9;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #eef5ef;
}

.travel-info {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #effaf2;
  border-bottom: 1rpx solid #e0f0e5;
}

.travel-icon {
  font-size: 26rpx;
  margin-right: 10rpx;
}

.travel-text {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: 500;
}

.spot-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.spot-image {
  width: 100%;
  height: 100%;
}

.spot-order {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(39, 174, 96, 0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.spot-order-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.spot-info {
  padding: 20rpx;
}

.spot-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.spot-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.spot-duration {
  padding: 4rpx 14rpx;
  background: #effaf2;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.duration-text {
  font-size: 22rpx;
  color: #52c41a;
  font-weight: 500;
}

.spot-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* ==================== 餐饮住宿 ==================== */
.day-extras {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.extra-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #fafafa;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.extra-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

/* ==================== 通用信息卡片 ==================== */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.info-card.last-card {
  margin-bottom: 40rpx;
}

.info-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-card-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.info-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 亮点列表 */
.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
}

.highlight-dot {
  font-size: 28rpx;
  color: #27AE60;
  font-weight: bold;
  margin-right: 14rpx;
  line-height: 1.6;
}

.highlight-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  flex: 1;
}

/* 费用包含网格 */
.include-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.include-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f6ffed;
  border: 1rpx solid #d9f7be;
  border-radius: 10rpx;
}

.include-check {
  font-size: 24rpx;
  color: #52c41a;
  font-weight: bold;
  margin-right: 10rpx;
}

.include-text {
  font-size: 25rpx;
  color: #555;
}

/* 温馨提示 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: #fffbe6;
  border-radius: 10rpx;
  border-left: 4rpx solid #faad14;
}

.tips-num {
  font-size: 24rpx;
  color: #faad14;
  font-weight: 600;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 25rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

/* 底部留白 */
.bottom-spacer {
  height: 60rpx;
}
